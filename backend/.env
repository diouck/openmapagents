# ═══════════════════════════════════════════════════════════════
# Overture Maps Explorer — Configuration
# Change LLM_PROVIDER + clé API une seule fois ici
# ═══════════════════════════════════════════════════════════════

# ─── LLM PROVIDER ─────────────────────────────────────────────
# Options: "claude", "openai", "ollama", "openrouter", "deepseek", "mistral"
LLM_PROVIDER=openai

# ─── MODELS PAR PROVIDER ──────────────────────────────────────
# Le format LiteLLM: "provider/model" ou juste "model" pour les directs
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=ollama/llama3.1
OPENROUTER_MODEL=openrouter/anthropic/claude-sonnet-4
DEEPSEEK_MODEL=deepseek/deepseek-chat
MISTRAL_MODEL=mistral/mistral-large-latest

# ─── API KEYS ─────────────────────────────────────────────────
# Remplir UNIQUEMENT la clé du provider choisi ci-dessus
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY= 
OPENROUTER_API_KEY=sk-or-xxxx
DEEPSEEK_API_KEY=sk-xxxx
MISTRAL_API_KEY=xxxx

# ─── OLLAMA (local, pas de clé) ──────────────────────────────
OLLAMA_API_BASE=http://localhost:11434

# ─── OVERTURE MAPS ────────────────────────────────────────────
OVERTURE_RELEASE=2026-03-18.0
OVERTURE_S3_REGION=us-west-2

# ─── DUCKDB ───────────────────────────────────────────────────
DUCKDB_MEMORY=4GB
DUCKDB_THREADS=4

# ─── SERVER ───────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
